# ─────────────────────────────────────────────
# Anthropic API
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Microsoft Fabric Warehouse
# ─────────────────────────────────────────────
DB_SERVER=tu-workspace.datawarehouse.fabric.microsoft.com
DB_DATABASE=nombre-de-la-base-de-datos

# Modo de autenticación:
#   sql                        → usuario + contraseña (Docker, servidores)
#   activedirectoryinteractive → MFA via browser    (solo desarrollo local sin Docker)
#   activedirectoryintegrated  → Windows auth       (solo dominio corporativo)
#   managedidentity            → sin credenciales   (solo Azure Container Apps en producción)
DB_AUTH_MODE=sql

# Solo requerido si DB_AUTH_MODE=sql
DB_USER=usuario@empresa.com
DB_PASSWORD=

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
FASTAPI_ENV=development
FASTAPI_DEBUG=true

# ─────────────────────────────────────────────
# Memoria local (SQLite)
# ─────────────────────────────────────────────
MEMORY_DB_PATH=./memory.db
